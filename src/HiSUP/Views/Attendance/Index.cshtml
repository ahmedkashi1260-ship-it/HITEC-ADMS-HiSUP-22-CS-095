@model IEnumerable<HiSUP.Models.AttendanceRecord>
@{
    ViewData["Title"] = "Attendance";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2><i class="fas fa-calendar-check me-2"></i>Attendance Records</h2>
            <p>View and mark student attendance</p>
        </div>
        <a href="/Attendance/Mark" class="btn btn-light btn-lg">
            <i class="fas fa-plus-circle me-2"></i>Mark Attendance
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="table-card">
    <div class="card-header">
        <i class="fas fa-list me-2"></i>Recent Records (last 50)
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Student</th>
                    <th>Section</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var record in Model)
                {
                    <tr>
                        <td>@record.AttendanceDate.ToString("dd-MMM-yyyy")</td>
                        <td>@record.Student?.FirstName @record.Student?.LastName</td>
                        <td>@record.Section?.SectionName</td>
                        <td>
                            @if (record.Status == "Present")
                            {
                                <span class="badge-active">Present</span>
                            }
                            else if (record.Status == "Absent")
                            {
                                <span class="badge-inactive">Absent</span>
                            }
                            else
                            {
                                <span class="badge-pending">Leave</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>