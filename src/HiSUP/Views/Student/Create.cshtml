@model HiSUP.Models.Student
@{
    ViewData["Title"] = "Add Student";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2><i class="fas fa-user-plus me-2"></i>Add New Student</h2>
            <p>Register a new student in HiSUP system</p>
        </div>
        <a href="/Student" class="btn btn-light">
            <i class="fas fa-arrow-left me-2"></i>Back to Students
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="table-card">
            <div class="card-header">
                <i class="fas fa-user-graduate me-2"></i>Student Registration Form
            </div>
            <div class="p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">
                                <i class="fas fa-user me-1 text-primary"></i>First Name
                            </label>
                            <input asp-for="FirstName" class="form-control" 
                                   placeholder="Enter first name" required />
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">
                                <i class="fas fa-user me-1 text-primary"></i>Last Name
                            </label>
                            <input asp-for="LastName" class="form-control" 
                                   placeholder="Enter last name" required />
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">
                                <i class="fas fa-envelope me-1 text-primary"></i>Email
                            </label>
                            <input asp-for="Email" class="form-control" 
                                   placeholder="student@hitec.edu.pk" required />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">
                                <i class="fas fa-id-card me-1 text-primary"></i>Roll Number
                            </label>
                            <input asp-for="RollNumber" class="form-control" 
                                   placeholder="CS-2025-001" required />
                            <span asp-validation-for="RollNumber" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">
                                <i class="fas fa-building me-1 text-primary"></i>Department
                            </label>
                            <select asp-for="DepartmentID" class="form-select" required>
                                <option value="">-- Select Department --</option>
                                @foreach (var dept in ViewBag.Departments)
                                {
                                    <option value="@dept.DepartmentID">@dept.DeptName</option>
                                }
                            </select>
                            <span asp-validation-for="DepartmentID" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">
                                <i class="fas fa-calendar me-1 text-primary"></i>Enrollment Year
                            </label>
                            <input asp-for="EnrollmentYear" class="form-control" 
                                   type="number" value="2025" min="2000" max="2030" required />
                            <span asp-validation-for="EnrollmentYear" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">
                                <i class="fas fa-phone me-1 text-primary"></i>Phone
                            </label>
                            <input asp-for="Phone" class="form-control" 
                                   placeholder="03001234567" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">
                                <i class="fas fa-venus-mars me-1 text-primary"></i>Gender
                            </label>
                            <select asp-for="Gender" class="form-select">
                                <option value="">-- Select Gender --</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="col-12 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg px-5">
                                <i class="fas fa-save me-2"></i>Register Student
                            </button>
                            <a href="/Student" class="btn btn-outline-secondary btn-lg ms-2 px-5">
                                <i class="fas fa-times me-2"></i>Cancel
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>