@model IEnumerable<HiSUP.Models.AuditLog>
@{
    ViewData["Title"] = "Audit Log";
}

<div class="page-header" style="background: linear-gradient(135deg, #4a148c, #ab47bc);">
    <div>
        <h2><i class="fas fa-history me-2"></i>Audit Log</h2>
        <p>System-wide record of INSERT, UPDATE, and DELETE operations</p>
    </div>
</div>

<div class="table-card mb-3">
    <div class="card-header" style="background: linear-gradient(135deg, #4a148c, #ab47bc);">
        <i class="fas fa-filter me-2"></i>Filter by Table
    </div>
    <div class="p-3">
        <form method="get" class="d-flex gap-2">
            <select name="tableFilter" class="form-select" style="max-width: 300px;">
                <option value="">-- All Tables --</option>
                <option value="Students" selected="@(ViewBag.TableFilter == "Students")">Students</option>
                <option value="FeePayments" selected="@(ViewBag.TableFilter == "FeePayments")">FeePayments</option>
                <option value="Grades" selected="@(ViewBag.TableFilter == "Grades")">Grades</option>
            </select>
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-search me-1"></i>Filter
            </button>
            <a href="/AuditLog" class="btn btn-outline-secondary">Clear</a>
        </form>
    </div>
</div>

<div class="table-card">
    <div class="card-header" style="background: linear-gradient(135deg, #4a148c, #ab47bc);">
        <i class="fas fa-list me-2"></i>Log Entries (@Model.Count() shown, last 100)
    </div>
    <div class="table-responsive">
        @if (Model.Any())
        {
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Table</th>
                        <th>Operation</th>
                        <th>Record ID</th>
                        <th>Old Value</th>
                        <th>New Value</th>
                        <th>Changed By</th>
                        <th>Timestamp</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td><strong>@log.TableName</strong></td>
                            <td>
                                @if (log.OperationType == "INSERT")
                                {
                                    <span class="badge bg-success">INSERT</span>
                                }
                                else if (log.OperationType == "UPDATE")
                                {
                                    <span class="badge bg-warning text-dark">UPDATE</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">DELETE</span>
                                }
                            </td>
                            <td>@log.RecordID</td>
                            <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis;">@log.OldValue</td>
                            <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis;">@log.NewValue</td>
                            <td>@log.ChangedBy</td>
                            <td>@log.ChangedAt.ToString("dd-MMM-yyyy HH:mm:ss")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="p-4 text-center text-muted">
                <i class="fas fa-info-circle fa-3x mb-3"></i>
                <p>No audit log entries yet.</p>
            </div>
        }
    </div>
</div>